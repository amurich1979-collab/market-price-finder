PORT=5177

# Required only for Apify-backed adapters.
APIFY_TOKEN=

# Optional ScrapeGraphAI integration.
# Used as the primary Ozon source and fallback for WB/Yandex.
SGAI_API_KEY=
SCRAPEGRAPH_ENDPOINT=https://v2-api.scrapegraphai.com/api/extract
SCRAPEGRAPH_TIMEOUT_MS=45000
SCRAPEGRAPH_COUNTRY=ru
SCRAPEGRAPH_STEALTH=true

# Ozon is intentionally Apify-only in this project.
OZON_ACTOR_ID=isolovyev/ru-marketplaces-price-monitor
OZON_TIMEOUT_MS=90000
OZON_MAX_ITEMS=50
OZON_SCRAPEGRAPH_TIMEOUT_MS=45000

# Optional Apify fallback for Wildberries when search.wb.ru returns 429/empty.
WB_ACTOR_ID=isolovyev/ru-marketplaces-price-monitor
WB_ACTOR_TIMEOUT_MS=90000
WB_MAX_ITEMS=50
WB_SCRAPEGRAPH_TIMEOUT_MS=30000

# Optional fallback actor for Yandex Market if page JSON parsing returns nothing.
YANDEX_ACTOR_ID=
YANDEX_TIMEOUT_MS=15000
YANDEX_ACTOR_TIMEOUT_MS=35000
YANDEX_MAX_ITEMS=50
YANDEX_SCRAPEGRAPH_TIMEOUT_MS=30000

# Wildberries public endpoint timeout.
WB_TIMEOUT_MS=12000

# Include adapter diagnostics in API responses while debugging.
DEBUG_SEARCH=false

# Legacy/shared Apify knobs.
APIFY_MAX_PAGES=1
APIFY_MAX_ITEMS=50
